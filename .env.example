# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/finance_db"

# JWT
JWT_ACCESS_SECRET=YoursSuperSecretAccessKeyChangeThisInProduction
JWT_REFRESH_SECRET=YoursSuperSecretAccessKeyChangeThisInProduction
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12